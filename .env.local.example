# Supabase — copia este fichero a .env.local y rellena tus valores reales.
# Encuéntralos en: supabase.com → tu proyecto → Settings → API
#
# IMPORTANTE: .env.local ya está en .gitignore → nunca se sube al repo.
# Este fichero (.env.local.example) sí va al repo como plantilla.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Modo invitado: muestra el botón "Continuar sin cuenta" en /entrar.
# Ponlo a "true" para activarlo, bórralo o ponlo a "false" para desactivarlo.
NEXT_PUBLIC_GUEST_MODE=true
